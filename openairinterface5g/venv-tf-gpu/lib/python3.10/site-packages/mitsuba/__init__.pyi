    @overload
    def __init__(self, type: MicrofacetType, alpha_u: drjit.auto.ad.Float, alpha_v: drjit.auto.ad.Float, sample_visible: bool = True) -> None: ...

    @overload
    def __init__(self, arg: Properties, /) -> None: ...

